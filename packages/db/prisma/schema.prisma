// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SectionSlug {
  printing
  mementoes
  corporate_gifts
}

model Section {
  id        String      @id @default(cuid())
  slug      SectionSlug @unique
  label     String
  tagline   String
  heroSlides HeroSlide[]
  services  Service[]
  gallery   GalleryItem[]
  testimonials Testimonial[]
  updatedAt DateTime    @updatedAt
  createdAt DateTime    @default(now())
}

model HeroSlide {
  id            String  @id @default(cuid())
  section       Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId     String
  image         String
  eyebrow       String
  heading       String
  headingAccent String
  intro         String
  order         Int     @default(0)
}

model Service {
  id          String  @id @default(cuid())
  section     Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId   String
  title       String
  description String
  order       Int     @default(0)
}

model GalleryItem {
  id        String  @id @default(cuid())
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId String
  image     String
  caption   String?
  order     Int     @default(0)
}

model Testimonial {
  id        String  @id @default(cuid())
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId String
  author    String
  quote     String
  order     Int     @default(0)
}
